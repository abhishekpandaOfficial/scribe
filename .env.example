# -------------------------
# Frontend (Vite)
# -------------------------
VITE_API_URL=http://127.0.0.1:8787

# If frontend directly needs Supabase in Vite client code
VITE_SUPABASE_URL=https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# -------------------------
# Backend Core
# -------------------------
API_PORT=8787
JWT_SECRET=change-me-in-production
DB_PATH=backend/data/scribe.db
APP_BASE_URL=http://127.0.0.1:4173
DATA_PROVIDER=sqlite
# Set to "supabase" after running `npm run supabase:bind`
# DATA_PROVIDER=supabase
CACHE_TTL_SECONDS=90

# -------------------------
# Supabase (shared)
# -------------------------
# Keep NEXT_PUBLIC_* for compatibility if you later move to Next.js
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_PROJECT_REF=abcd1234efgh5678
# Optional: only needed if Supabase CLI asks for DB password during link/push
SUPABASE_DB_PASSWORD=your-db-password
SUPABASE_MIGRATE_BATCH_SIZE=500

# -------------------------
# Auth
# -------------------------
NEXTAUTH_SECRET=openssl-rand-32-bytes
NEXTAUTH_URL=https://scribe.dev

# -------------------------
# Storage (Supabase now, optional R2 later)
# -------------------------
CLOUDFLARE_R2_BUCKET=scribe-media
CLOUDFLARE_R2_ENDPOINT=https://xxx.r2.cloudflarestorage.com
CLOUDFLARE_R2_ACCESS_KEY=xxx
CLOUDFLARE_R2_SECRET_KEY=xxx

# -------------------------
# Webhooks / Events
# -------------------------
INNGEST_EVENT_KEY=xxx
INNGEST_SIGNING_KEY=xxx

# -------------------------
# Payments
# -------------------------
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
# Vite-compatible publishable key name (optional)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_xxx

# -------------------------
# Email
# -------------------------
RESEND_API_KEY=re_xxx

# -------------------------
# Cache (Upstash Redis)
# -------------------------
UPSTASH_REDIS_URL=https://xxx.upstash.io
UPSTASH_REDIS_TOKEN=xxx

# -------------------------
# Analytics
# -------------------------
TINYBIRD_TOKEN=xxx
